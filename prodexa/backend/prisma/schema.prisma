datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  githubLogin  String?
  avatarUrl    String?
  passwordHash String?
  githubToken  String?
  role         Role     @default(MANAGER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  projects      Project[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@index([email])
  @@index([role])
}

model Project {
  id             String         @id @default(uuid())
  name           String
  repoUrl        String
  ownerName      String
  repoOwner      String?
  repoName       String?
  status         ProjectStatus  @default(ACTIVE)
  analysisStatus AnalysisStatus @default(IDLE)
  lastSyncedAt   DateTime?
  cacheExpiresAt DateTime?
  lastError      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  metrics             ProjectActivity[]
  predictions         Prediction[]
  developerActivities DeveloperActivity[]
  notifications       Notification[]

  @@index([userId])
  @@index([status])
  @@index([analysisStatus])
  @@index([lastSyncedAt])
}

model ProjectActivity {
  id                String   @id @default(uuid())
  projectId         String
  commitFrequency   Int
  pullRequestCount  Int
  issueCount        Int
  contributorCount  Int
  productivityScore Int?
  activityTimestamp DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([activityTimestamp])
}

model Prediction {
  id                String   @id @default(uuid())
  projectId         String
  productivityScore Float
  deliveryRisk      String
  workloadForecast  Float
  teamHealthStatus  String?
  generatedAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([generatedAt])
}

model DeveloperActivity {
  id                String   @id @default(uuid())
  projectId         String
  developerLogin    String
  avatarUrl         String?
  commits           Int      @default(0)
  pullRequestCount  Int      @default(0)
  issueCount        Int      @default(0)
  productivityScore Int      @default(0)
  predictedScore    Int?
  trend             String?
  riskLevel         String?
  activityTimestamp DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([developerLogin, projectId])
  @@index([projectId])
  @@index([productivityScore])
  @@index([developerLogin])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  projectId String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isRead])
  @@index([userId, isRead])
  @@index([createdAt])
}

enum Role {
  ADMIN
  MANAGER
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
}

enum AnalysisStatus {
  IDLE
  QUEUED
  ANALYZING
  DONE
  FAILED
}

enum NotificationType {
  PRODUCTIVITY_DROP
  HIGH_DELIVERY_RISK
  INACTIVE_DEVELOPER
  ANALYSIS_COMPLETE
  SYSTEM_ALERT
}

model DailyMetricsSnapshot {
  id String @id @default(cuid())

  projectId String

  date DateTime

  totalCommits Int @default(0)

  activeContributors Int @default(0)

  totalPullRequests Int @default(0)

  mergedPullRequests Int @default(0)

  totalIssues Int @default(0)

  closedIssues Int @default(0)

  averagePRMergeTime Float?

  commitVelocity Float?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([projectId, date])
  @@index([projectId])
  @@index([date])
}

model CommitEvent {
  id String @id @default(cuid())

  sha String @unique

  repositoryId String

  repositoryName String

  authorLogin String

  message String

  branch String

  commitUrl String

  committedAt DateTime

  createdAt DateTime @default(now())

  impactAnalysis CommitImpactAnalysis?

  @@index([repositoryId])
  @@index([authorLogin])
  @@index([committedAt])
  @@index([branch])
}

model PullRequestEvent {
  id String @id @default(cuid())

  githubPrId Int @unique

  repositoryId String

  repositoryName String

  authorLogin String

  title String

  state String

  action String

  branch String

  baseBranch String

  isDraft Boolean @default(false)

  additions Int @default(0)

  deletions Int @default(0)

  changedFiles Int @default(0)

  commitsCount Int @default(0)

  createdAtGithub DateTime

  mergedAtGithub DateTime?

  closedAtGithub DateTime?

  createdAt DateTime @default(now())

  @@index([repositoryId])
  @@index([authorLogin])
  @@index([state])
  @@index([createdAtGithub])
}

model EngineeringKPI {
  id String @id @default(cuid())

  repositoryId String

  developerLogin String?

  metricName String

  metricValue Float

  metricDate DateTime

  metadata Json?

  createdAt DateTime @default(now())

  @@index([repositoryId])
  @@index([developerLogin])
  @@index([metricName])
  @@index([metricDate])
}

model CommitFileChange {
  id String @id @default(cuid())

  commitSha String

  filename String

  status String

  additions Int @default(0)

  deletions Int @default(0)

  changes Int @default(0)

  patch String?

  fileExtension String?

  isTestFile Boolean @default(false)

  isDocumentation Boolean @default(false)

  isConfigFile Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([commitSha])
  @@index([filename])
  @@index([fileExtension])
}

model CommitImpactAnalysis {
  id String @id @default(cuid())

  commitSha String @unique

  impactScore Float @default(0)

  riskScore Float @default(0)

  meaningfulnessScore Float @default(0)

  impactLevel String

  riskLevel String

  summary String?

  reasons Json?

  createdAt DateTime @default(now())

  commit CommitEvent @relation(fields: [commitSha], references: [sha], onDelete: Cascade)

  @@index([impactScore])
  @@index([riskScore])
  @@index([impactLevel])
}
